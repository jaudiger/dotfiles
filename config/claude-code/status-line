# Format a number with K/M suffix for readability
def format_number [n: int]: nothing -> string {
    if $n >= 1_000_000 {
        $"($n / 1_000_000
          | math round --precision 1)M"
    } else if $n >= 1_000 {
        $"($n / 1_000
          | math round --precision 1)k"
    } else {
        $n
          | into string
    }
}

def status_line [input: record]: nothing -> nothing {
    # Extract cumulative token usage across the session (default to 0 if missing)
    let input_tokens = $input
      | get -o context_window.total_input_tokens
      | default 0
    let output_tokens = $input
      | get -o context_window.total_output_tokens
      | default 0

    # Extract cache-read tokens (default to 0 if missing or null)
    let cache_read_tokens = $input
      | get -o context_window.current_usage.cache_read_input_tokens
      | default 0

    # Extract exceeds 200k token threshold flag
    let exceeds_200k = $input
      | get -o exceeds_200k_tokens
      | default false

    # Extract context window usage percentage
    let context_pct = $input
      | get -o context_window.used_percentage
      | default 0
      | math round

    # Context % color: blue < 50%, orange 50-80%, red > 80%
    let context_color = if $context_pct >= 80 {
        (ansi red)
    } else if $context_pct >= 50 {
        (ansi xterm_orange1)
    } else {
        (ansi blue)
    }

    # Extract lines changed (default to 0 if missing)
    let lines_added = $input
      | get -o cost.total_lines_added
      | default 0
    let lines_removed = $input
      | get -o cost.total_lines_removed
      | default 0

    # Extract cost (2 decimals)
    let cost = $input
      | get -o cost.total_cost_usd
      | default 0
      | into string --decimals 2

    # Extract rate limits (available after first API response)
    let rate_5h = $input
      | get -o rate_limits.five_hour.used_percentage
      | default null
    let rate_7d = $input
      | get -o rate_limits.seven_day.used_percentage
      | default null
    # Color a rate limit percentage: none < 50%, orange 50-80%, red >= 80%
    let rate_color = {|pct| if $pct >= 80 {
        (ansi red)
    } else if $pct >= 50 {
        (ansi xterm_orange1)
    } else {
        (ansi reset)
    }}

    # Build output: ↑0/↓0 ⚡0 [0%] ⚠ | +0/-0 | $0.00 | 5h:0%/7d:0%
    let tokens = $"(ansi green)↑(format_number $input_tokens)(ansi reset)/(ansi yellow)↓(format_number $output_tokens)(ansi reset)"
    let cache = if $cache_read_tokens > 0 {
        $" (ansi cyan)⚡(format_number $cache_read_tokens)(ansi reset)"
    } else {
        ""
    }
    let context = $"($context_color)[($context_pct)%](ansi reset)"
    let warn_200k = if $exceeds_200k {
        $" (ansi red)⚠(ansi reset)"
    } else {
        ""
    }
    let lines = $"(ansi green)+($lines_added)(ansi reset)/(ansi red)-($lines_removed)(ansi reset)"
    let cost_str = $"$($cost)"
    let rate_str = if $rate_5h != null and $rate_7d != null {
        let c5 = do $rate_color ($rate_5h | math round)
        let c7 = do $rate_color ($rate_7d | math round)
        $" | ($c5)5h:($rate_5h | math round)%(ansi reset)/($c7)7d:($rate_7d | math round)%(ansi reset)"
    } else {
        ""
    }

    print -n $"($tokens)($cache) ($context)($warn_200k) | ($lines) | ($cost_str)($rate_str)"
}

# Status line function for Claude Code UI
def main [
    ...args: any # Additional arguments
]: nothing -> nothing {
    # Read and parse JSON from stdin
    let input = $in | from json

    status_line $input
}
